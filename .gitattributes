# Normalize line endings — checkout LF on all platforms
* text=auto eol=lf

# Explicit text files
*.md       text eol=lf
*.json     text eol=lf
*.js       text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.rs       text eol=lf
*.toml     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.sh       text eol=lf
*.gitignore text eol=lf

# Binary files
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.icns     binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
*.flac     binary
*.mp3      binary
*.wav      binary
*.zip      binary
